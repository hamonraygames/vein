; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="VEIN"
run/main_scene="res://scenes/game.tscn"
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://icon.svg"

[autoload]

Beat="*res://scripts/beat.gd"
Audio="*res://scripts/audio.gd"

[display]

window/size/viewport_width=540
window/size/viewport_height=1170
; Desktop-only window size. The design space above (540x1170) is a real phone
; aspect (19.5:9, e.g. iPhone 12+ at 1170px tall), so this is NOT a made-up
; shape — but on a laptop the window is bounded by screen height, and at
; 432x936 it was rendering the 540-wide design space at 80% scale, which is why
; everything read as small. This fills the available height instead (~975 of a
; typical 982-point laptop workspace) so the board renders near 1:1.
window/size/window_width_override=450
window/size/window_height_override=975
window/stretch/mode="canvas_items"
; "expand" reveals MORE of the game world at an unchanged pixel scale rather
; than scaling the board to fit the window — harmless on a phone (the design
; aspect already matches real phone screens almost exactly) or the desktop
; editor window above (already sized to the same 540:1170 aspect, so there
; is no mismatch to resolve either way). But a browser tab can be ANY size,
; and at a typical 1280x800 laptop viewport "expand" rendered the board at
; native 1:1 scale in the top-left corner with the bottom of the board
; (budget strokes, score) clipped off-screen entirely below y=800 — not
; "small", actually not there. "keep" scales the whole 540x1170 board
; uniformly to fit whatever window it's given, pillarboxed if the aspect
; doesn't match, which is what actually guarantees every element is both
; visible and legibly sized regardless of window shape.
window/stretch/aspect="keep"
window/handheld/orientation=1

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="mobile"
anti_aliasing/quality/msaa_2d=2
environment/defaults/default_clear_color=Color(0.051, 0.051, 0.063, 1)
